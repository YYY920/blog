---
import ToolSection from '@/components/about/ToolSection.astro'
import PageLayout from '@/layouts/CommonPage.astro'

const headings = [
  { depth: 2, slug: 'about', text: 'About Me' },
  { depth: 2, slug: 'contact', text: 'Contact' },
  { depth: 2, slug: 'tools', text: 'Tools' },
]
---

<PageLayout title='About' {headings}>
  <p>Full Stack Developer / AI Automation Specialist</p>
  <p>
    Currently working as IT Consultant at Peak Advisory, building agentic AI solutions and workflow automation for real-world business processes.
  </p>
  <p>
    Graduated with a Master of Information Technology (With Distinction, Top 10%) from the University of Melbourne. Experienced across the full stack — from React frontends and Node.js APIs to Python data pipelines, RAG systems, and cloud deployments on AWS/Azure.
  </p>


  <h2 id='contact'>Contact</h2>
  <ul>
    <li>Email: <a href='mailto:jennyyang920@gmail.com'>jennyyang920@gmail.com</a></li>
    <li>LinkedIn: <a href='https://www.linkedin.com/in/yingyu-jenny-yang/' target='_blank' rel='noopener noreferrer'>linkedin.com/in/yingyu-jenny-yang</a></li>
    <li>GitHub: <a href='https://github.com/YYY920' target='_blank' rel='noopener noreferrer'>github.com/YYY920</a></li>
  </ul>
   {/* tools */}
   <h2 id='tools'>Tools</h2>
   <p>Here are the tools and technologies I use daily:</p>
   <ToolSection
     class='mb-5'
     title='AI & Code Assistants'
     tools={[
       {
         name: 'ChatGPT',
         description: 'AI Assistant',
         href: 'https://chat.openai.com/',
         icon: import('@/assets/tools/chatgpt.svg?raw')
       },
      
     ]}
   />
   
</PageLayout>
